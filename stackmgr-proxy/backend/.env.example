PORT=8080
STACKS_PATH=/localstack/nodes
# Path to nodes on the remote host (used to parse env from Docker compose labels).
# Set this when DOCKER_HOST points to a remote machine whose paths differ from STACKS_PATH.
# e.g. for dietpi: REMOTE_STACKS_PATH=/mnt/data/localstack/nodes
REMOTE_STACKS_PATH=/home/dietpi/localstack/repo/nodes
# SSH URI format — uses SSH agent socket for auth, no manual tunnel needed:
#   single:   DOCKER_HOST=ab=ssh://dietpi@10.10.10.11
#   multi:    DOCKER_HOST=ab=ssh://dietpi@10.10.10.11,cd=unix:///var/run/docker.sock
#   bare URL (node named "local"): DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_HOST=ab=ssh://dietpi@10.10.10.11

# SSH agent socket — pin this so the backend always uses the right agent.
# Find yours: echo $SSH_AUTH_SOCK
# macOS system agent: /private/tmp/com.apple.launchd.XXXXX/Listeners
# 1Password:          ~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock
SSH_AUTH_SOCK=
